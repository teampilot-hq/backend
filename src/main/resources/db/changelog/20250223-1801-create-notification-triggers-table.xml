<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
    <changeSet id="20250223-1801-create-notification-triggers-table" author="M.Karimi">
        <createTable tableName="notification_triggers">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITHOUT TIME ZONE"/>
            <column name="updated_at" type="TIMESTAMP WITHOUT TIME ZONE"/>
            <column name="event_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="template_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="channels" type="VARCHAR[]">
                <constraints nullable="false"/>
            </column>
            <column name="receptors" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="organization_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createSequence sequenceName="notification_trigger_id_seq" startValue="1" incrementBy="10"/>

        <addForeignKeyConstraint
                baseTableName="notification_triggers"
                baseColumnNames="template_id"
                referencedTableName="notification_templates"
                referencedColumnNames="id"
                constraintName="fk_notification_triggers_template_id"/>

        <addForeignKeyConstraint
                baseTableName="notification_triggers"
                baseColumnNames="organization_id"
                referencedTableName="organizations"
                referencedColumnNames="id"
                constraintName="fk_notification_triggers_organization_id"/>
    </changeSet>
</databaseChangeLog> 